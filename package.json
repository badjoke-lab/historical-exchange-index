  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "typescript": "5.8.2"
